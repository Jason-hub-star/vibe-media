# Supabase
SUPABASE_DB_URL=postgresql://postgres.project-ref:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# Safety switch for legacy cleanup worker
SUPABASE_CLEANUP_COMMIT=0

# Supabase keys (unused by current backend, needed for future SSR auth)
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Video watch folder worker
VIDEO_WATCH_DIR=apps/backend/state/watch-folder
VIDEO_WATCH_POLLING_MS=5000
VIDEO_WATCH_STABLE_OBSERVATIONS=2

# Telegram pipeline report (M6)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_REPORT_CHAT_ID=your-chat-id-here

# Media engine (image/text generation)
KIE_API_KEY=your-kie-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
IMAGE_PROVIDER=kie
USE_MOCK=false
